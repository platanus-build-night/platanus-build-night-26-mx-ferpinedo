PORT=3000
BASE_URL=http://localhost:3000
PUBLIC_FILES_URL=
STORAGE_DIR=generated

# Image generation. auto uses OpenAI when OPENAI_API_KEY exists, otherwise local mock stickers.
IMAGE_GENERATION_MODE=auto
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Kapso sending. Leave disabled for local webhook testing.
KAPSO_ENABLED=false
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_SEND_MESSAGE_PATH=/whatsapp/messages
KAPSO_SEND_MESSAGE_URL=
KAPSO_WHATSAPP_FROM=

# Comma-separated phone numbers Sticky must fully ignore (no reply at all).
# Example: BLOCKED_NUMBERS=+52 1 55 8706 9436,+52 1 871 178 9663
BLOCKED_NUMBERS=
